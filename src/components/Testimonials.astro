---
// Review Schema para Google
const reviewsSchema = {
  "@context": "https://schema.org",
  "@type": "AggregateRating",
  "itemReviewed": {
    "@type": "LocalBusiness",
    "name": "EO Marido de Aluguel",
    "url": "https://eomaridodealuguel.com.br"
  },
  "ratingValue": "5",
  "bestRating": "5",
  "worstRating": "1",
  "ratingCount": "3",
  "reviewCount": "3"
};

const reviews = [
  {
    name: "Carlos M.",
    company: "Empresário, Plano Piloto",
    text: "Chamei a MM Entulho para minha reforma no Plano Piloto. Entrega em menos de 2 horas! Excelente. Já recomendei para vários colegas. Voltarei a usar com certeza.",
    initials: "CM",
    rating: 5
  },
  {
    name: "Ana S.",
    company: "Construtora, Taguatinga",
    text: "Orçamento rápido, sem surpresas no preço. Entulho coletado e levado para local correto. Usamos em várias obras aqui em Taguatinga. Recomendo demais!",
    initials: "AS",
    rating: 5
  },
  {
    name: "Roberto L.",
    company: "Síndico, Ceilândia",
    text: "Precisei de caçamba urgente para limpeza da garagem. Falei pelo WhatsApp e resolveram rápido. Empresa séria, responsável. Muito bom mesmo!",
    initials: "RL",
    rating: 5
  }
];
---

<!-- Aggregate Rating Schema JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(reviewsSchema)}></script>

<section class="py-12 md:py-20 lg:py-24 bg-gradient-to-br from-primary to-secondary relative overflow-hidden">
  {/* Decorative elements */}
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -mr-48 -mt-48"></div>
  <div class="absolute bottom-0 left-0 w-72 h-72 bg-white/5 rounded-full -ml-36 -mb-36"></div>

  <div class="container mx-auto px-4 md:px-6 relative z-10">
    <div class="text-center mb-12 md:mb-16">
      <span class="inline-block px-4 py-2 rounded-full text-sm font-semibold mb-4 bg-white/20 text-white">
        ⭐ Clientes Satisfeitos
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-4xl font-bold text-white mb-4">
        O que dizem nossos clientes
      </h2>
      <p class="text-base md:text-lg text-gray-100 max-w-2xl mx-auto">
        Milhares de clientes satisfeitos com nosso serviço de aluguel de caçambas em Brasília
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 lg:gap-10">
      {reviews.map((review, index) => (
        <div class={`
          relative group
          bg-white/95 backdrop-blur-sm p-6 md:p-8 rounded-xl
          border border-white/20
          transition-all duration-300
          hover:shadow-2xl hover:scale-105 hover:bg-white
          ${index === 0 ? 'md:scale-105 md:shadow-xl' : ''}
        `}>
          {/* Quote mark */}
          <div class="absolute top-4 right-6 text-6xl text-primary/10">
            "
          </div>

          {/* Star Rating with bg */}
          <div class="flex gap-1.5 mb-6 items-center bg-yellow-50 w-fit px-3 py-2 rounded-lg">
            {[...Array(review.rating)].map(() => (
              <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
            <span class="text-xs font-bold text-gray-700 ml-2">5/5</span>
          </div>

          {/* Review Text */}
          <p class="text-gray-700 mb-8 leading-relaxed text-base md:text-lg font-medium">
            "{review.text}"
          </p>

          {/* Author Info - Enhanced */}
          <div class="flex items-center gap-4 pt-6 border-t border-gray-200">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-primary to-orange-700 text-white flex items-center justify-center font-bold text-sm flex-shrink-0 shadow-md">
              {review.initials}
            </div>
            <div class="flex-1 min-w-0">
              <h4 class="font-bold text-gray-900 text-sm md:text-base">{review.name}</h4>
              <p class="text-xs text-gray-600 truncate">{review.company}</p>
              <div class="flex items-center gap-1 mt-1">
                <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="text-xs text-gray-600">Verificado</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Stats */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mt-16 md:mt-20">
      {[
        { value: '2.000+', label: 'Clientes Atendidos' },
        { value: '5.0', label: 'Avaliação Média' },
        { value: '10+', label: 'Anos de Experiência' },
        { value: '24h', label: 'Atendimento Rápido' }
      ].map((stat) => (
        <div class="text-center">
          <p class="text-2xl md:text-4xl font-bold text-white mb-2">
            {stat.value}
          </p>
          <p class="text-sm md:text-base text-gray-200">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
