---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import GoogleMap from '@components/GoogleMap.astro';
import FAQ from '@components/FAQ.astro';

// Breadcrumb items
const breadcrumbItems = [
  { name: 'Início', url: '/' },
  { name: 'Contato', url: '/contato' }
];

// Contact information
const contactInfo = [
  {
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    label: 'Email',
    value: 'contato@mmentulho.com.br',
    href: 'mailto:contato@mmentulho.com.br'
  },
  {
    icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
    label: 'WhatsApp',
    value: '(61) 97402-2227',
    href: 'https://wa.me/+5561974022227?text=Gostaria%20de%20or%C3%A7amento%20de%20ca%C3%A7ambras%20para%20entulhos'
  },
  {
    icon: 'M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z',
    label: 'Localização',
    value: 'Brasília - DF',
    href: '#'
  }
];

// Organization Schema with contact
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "MM Entulho",
  "url": "https://mmentulho.com.br",
  "logo": "https://mmentulho.com.br/logo.png",
  "email": "contato@mmentulho.com.br",
  "telephone": "+55-61-97402-2227",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Brasília",
    "addressLocality": "Distrito Federal",
    "addressRegion": "DF",
    "addressCountry": "BR"
  },
  "sameAs": [
    "https://www.facebook.com/mmentulho",
    "https://www.instagram.com/mmentulho"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Service",
    "telephone": "+55-61-97402-2227",
    "email": "contato@mmentulho.com.br",
    "areaServed": "Brasília, DF",
    "availableLanguage": ["pt-BR"]
  }
};
---

<BaseLayout title="Contato - MM Entulho | Remoção de Entulho em Brasília" description="Entre em contato com MM Entulho para solicitar orçamento de locação de caçamba, tele entulho ou remoção de entulho. Responderemos em até 2 horas. WhatsApp e telefone disponível 24h!">
  {/* Organization Schema */}
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>

  {/* Hero Section */}
  <section class="py-20 md:py-32 bg-yellow-600 text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        Fale Conosco
      </h1>
      <p class="text-xl md:text-2xl text-white max-w-3xl mx-auto">
        Estamos prontos para resolver sua necessidade de entulho com rapidez e segurança. Responderemos em até 2 horas!
      </p>
    </div>
  </section>

  {/* Breadcrumb */}
  <Breadcrumb items={breadcrumbItems} />

  {/* Contact Information */}
  <section class="py-12 md:py-16 lg:py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {contactInfo.map((info) => (
          <div class="bg-white p-8 rounded-lg shadow-md text-center hover:shadow-lg transition-shadow">
            <div class="w-16 h-16 bg-yellow-100 rounded-lg flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={info.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{info.label}</h3>
            {info.href !== '#' ? (
              <a href={info.href} class="text-yellow-600 font-semibold hover:text-yellow-700 transition-colors">
                {info.value}
              </a>
            ) : (
              <p class="text-gray-600">{info.value}</p>
            )}
          </div>
        ))}
      </div>

      {/* Social Links */}
      <div class="text-center mb-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Siga MM Entulho nas redes sociais</h3>
        <div class="flex gap-4 justify-center">
          <a href="https://www.facebook.com/mmentulho" class="w-12 h-12 bg-yellow-600 rounded-full flex items-center justify-center text-white hover:bg-yellow-700 transition-colors" aria-label="Facebook">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a href="https://www.instagram.com/mmentulho" class="w-12 h-12 bg-yellow-600 rounded-full flex items-center justify-center text-white hover:bg-yellow-700 transition-colors" aria-label="Instagram">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.466.182-.8.398-1.15.748-.35.35-.566.684-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.684.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.684.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" />
            </svg>
          </a>
          <a href="https://wa.me/+5561974022227?text=Gostaria%20de%20or%C3%A7amento%20de%20ca%C3%A7ambras%20para%20entulhos" class="w-12 h-12 bg-yellow-600 rounded-full flex items-center justify-center text-white hover:bg-yellow-700 transition-colors" aria-label="WhatsApp">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-4.895 1.238c-1.593.935-2.788 2.26-3.239 3.787a9.9 9.9 0 001.414-9.786 10.015 10.015 0 0112.343 5.25c.294.795.458 1.629.527 2.475 0 .016 0 .031-.002.047a10.02 10.02 0 01-5.144.767M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Contact Form */}
  <section id="contact-form" class="py-12 md:py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-4 max-w-2xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Envie Sua Mensagem
        </h2>
        <p class="text-lg text-gray-600">
          Preencha o formulário abaixo e nossa equipe entrará em contato em até 2 horas
        </p>
      </div>

      <form class="bg-gray-50 p-8 rounded-lg shadow-md">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          {/* Name */}
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-900 mb-2">
              Nome Completo *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-600 focus:border-transparent outline-none transition"
              placeholder="Seu nome"
            />
          </div>

          {/* Email */}
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-900 mb-2">
              Email *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-600 focus:border-transparent outline-none transition"
              placeholder="seu@email.com"
            />
          </div>

          {/* Phone */}
          <div>
            <label for="phone" class="block text-sm font-semibold text-gray-900 mb-2">
              Telefone / WhatsApp
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-600 focus:border-transparent outline-none transition"
              placeholder="(61) 9 XXXX-XXXX"
            />
          </div>
        </div>

        {/* Service Interest */}
        <div class="mb-6">
          <label for="service" class="block text-sm font-semibold text-gray-900 mb-2">
            Qual serviço você tem interesse? *
          </label>
          <select
            id="service"
            name="service"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-600 focus:border-transparent outline-none transition"
          >
            <option value="">Selecione um serviço</option>
            <option value="locacao-cacamba">Locação de Caçamba</option>
            <option value="tele-entulho">Tele Entulho</option>
            <option value="orcamento">Solicitar Orçamento</option>
            <option value="duvida">Dúvida Geral</option>
            <option value="outro">Outro</option>
          </select>
        </div>

        {/* Message */}
        <div class="mb-6">
          <label for="message" class="block text-sm font-semibold text-gray-900 mb-2">
            Mensagem *
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-600 focus:border-transparent outline-none transition"
            placeholder="Deixe sua mensagem aqui..."
          ></textarea>
        </div>

        {/* Privacy */}
        <div class="mb-6">
          <label class="flex items-start">
            <input
              type="checkbox"
              name="privacy"
              required
              class="w-4 h-4 mt-1 text-yellow-600 rounded focus:ring-2 focus:ring-yellow-600 cursor-pointer"
            />
            <span class="ml-3 text-sm text-gray-600">
              Eu concordo com a <a href="#" class="text-yellow-600 hover:text-yellow-700 font-semibold">política de privacidade</a> e autorizo o contato via WhatsApp ou email.
            </span>
          </label>
        </div>

        {/* Submit Button */}
        <button
          type="submit"
          class="w-full px-8 py-4 bg-yellow-600 text-white font-semibold rounded-lg hover:bg-yellow-700 transition-colors shadow-lg hover:shadow-xl active:scale-95"
        >
          Enviar Mensagem
        </button>

        <p class="text-center text-sm text-gray-600 mt-4">
          * Campos obrigatórios
        </p>
      </form>
    </div>
  </section>

  {/* Google Map Section */}
  <GoogleMap />

  {/* FAQ */}
  <FAQ />
</BaseLayout>
