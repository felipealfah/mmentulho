            <source srcset="/optimized/tele_entulho_brasilia-400w.avif 400w, /optimized/tele_entulho_brasilia-800w.avif 800w" type="image/avif" />
            <source srcset="/optimized/tele_entulho_brasilia-400w.webp 400w, /optimized/tele_entulho_brasilia-800w.webp 800w" type="image/webp" />
            <img src="/optimized/tele_entulho_brasilia-800w.jpg" alt="Serviço de remoção de entulho sob demanda em Brasília" class="w-full h-96 object-cover object-center bg-gray-200" width="800" height="600" decoding="async" loading="lazy" />
          </picture>
          <div class="p-6">
            <div class="inline-block bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-semibold mb-4">
