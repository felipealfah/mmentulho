---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import CTA from '@components/CTA.astro';

// SEO Schema - LocalBusiness
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "MM Entulho",
  "description": "Aluguel de caçambas de entulho e remoção sob demanda em Brasília e DF",
  "url": "https://mmentulho.com.br",
  "telephone": "+55 61 9 8404-5185",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Brasília",
    "addressLocality": "Brasília",
    "addressRegion": "DF",
    "postalCode": "72000-000",
    "addressCountry": "BR"
  },
  "areaServed": [
    "Brasília",
    "Águas Claras",
    "Taguatinga",
    "Ceilândia",
    "Gama",
    "Cácamabas",
    "Guará",
    "Samambaia",
    "Santa Maria",
    "Sobradinho"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Service",
    "telephone": "+55 61 9 8404-5185"
  }
};

// Service Schema
const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Serviços de Caçamba de Entulho",
  "description": "Aluguel de caçambas de entulho em diversos tamanhos para reformas, demolições e obras em Brasília",
  "provider": {
    "@type": "Organization",
    "name": "MM Entulho"
  },
  "areaServed": "Brasília, DF",
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceUrl": "https://wa.me/+5561974022227?text=Gostaria%20de%20or%C3%A7amento%20de%20ca%C3%A7ambras%20para%20entulhos"
  }
};

// Aggregate Rating Schema
const aggregateRatingSchema = {
  "@context": "https://schema.org",
  "@type": "AggregateRating",
  "ratingValue": "5",
  "ratingCount": "4",
  "bestRating": "5",
  "worstRating": "1"
};

const breadcrumbItems = [
  { label: 'Início', url: '/' },
  { label: 'Serviços', url: '/servicos' }
];
---

<BaseLayout
  title="Serviços de Caçamba de Entulho em Brasília | Locação e Tele Entulho | MM Entulho"
  description="Aluguel de caçambas de entulho + Tele Entulho em Brasília. Rápido, rastreado e autorizado pelo SLU. Orçamento grátis. WhatsApp: (61) 97402-2227"
>
  <!-- Schema.org Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(aggregateRatingSchema)} />

  <!-- Hero Section -->
  <section class="py-20 md:py-32 bg-yellow-600 text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Nossos Serviços
      </h1>
      <p class="text-xl md:text-2xl max-w-3xl mx-auto text-white">
        Soluções completas de aluguel e remoção de entulho em Brasília
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <Breadcrumb items={breadcrumbItems} />

  <!-- Introdução aos Serviços -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-8 text-center text-gray-900">Serviços de Caçambas MM Entulho</h2>

      <div class="space-y-6 text-gray-700 leading-relaxed">
        <p>
          Oferecemos soluções completas de aluguel e remoção de entulho em Brasília. Seja você uma família em reforma, uma construtora em grande obra ou uma empresa de desmonte, temos a solução ideal para remover entulho com rapidez, segurança e responsabilidade ambiental.
        </p>

        <p>
          Contamos com frota moderna de 40+ caçambas de diferentes tamanhos, entrega rápida (até 2 horas), rastreamento completo e destinação correta em aterros licenciados. Somos autorizados pelo SLU do Distrito Federal com controle legal de transporte de resíduos.
        </p>

        <p>
          Explore cada serviço abaixo e escolha a modalidade que melhor se adequa à sua necessidade. Para dúvidas, entre em contato conosco pelo WhatsApp!
        </p>
      </div>
    </div>
  </section>

  <!-- Lista de Serviços -->
  <section class="py-16 px-4" id="services-list">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-12 text-center text-gray-900">Nossos Serviços</h2>

      <div class="space-y-8">
        <!-- Card 1: Locação de Caçamba -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow border-t-4 border-yellow-600">
          <picture>
            <source srcset="/optimized/aluguel_cacamba_entulhobrasilia-400w.avif 400w, /optimized/aluguel_cacamba_entulhobrasilia-800w.avif 800w" type="image/avif" />
            <source srcset="/optimized/aluguel_cacamba_entulhobrasilia-400w.webp 400w, /optimized/aluguel_cacamba_entulhobrasilia-800w.webp 800w" type="image/webp" />
            <img src="/optimized/aluguel_cacamba_entulhobrasilia-800w.jpg" alt="Caçambas disponíveis para aluguel em Brasília" class="w-full h-96 object-cover object-bottom bg-gray-200" width="800" height="600" decoding="async" loading="lazy" />
          </picture>
          <div class="p-6">
            <div class="inline-block bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-semibold mb-4">
              Disponibilidade Imediata
            </div>

            <h3 class="text-2xl font-bold text-gray-900 mb-3">Locação de Caçamba de Entulho</h3>

            <p class="text-gray-600 mb-6">
              Aluguel de caçambas de entulho em diversos tamanhos (4m³, 6m³ e 8m³) para reformas, demolições e obras em Brasília e DF. Entrega rápida, caçamba limpa e rastreada, com responsabilidade ambiental garantida.
            </p>

            <div class="mb-6">
              <h4 class="font-semibold text-gray-900 mb-3">Destaques do Serviço:</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start">
                  <span class="text-yellow-600 mr-3 font-bold">✓</span>
                  <span>Caçamba vistoriada e rastreada em tempo real</span>
                </li>
                <li class="flex items-start">
                  <span class="text-yellow-600 mr-3 font-bold">✓</span>
                  <span>Descarte consciente em aterros licenciados</span>
                </li>
                <li class="flex items-start">
                  <span class="text-yellow-600 mr-3 font-bold">✓</span>
                  <span>Autorizado pelo SLU (Secretaria de Limpeza Urbana)</span>
                </li>
                <li class="flex items-start">
                  <span class="text-yellow-600 mr-3 font-bold">✓</span>
                  <span>Controle de Transporte de Resíduos (CTR) incluído</span>
                </li>
                <li class="flex items-start">
                  <span class="text-yellow-600 mr-3 font-bold">✓</span>
                  <span>Entrega rápida em até 2 horas</span>
                </li>
              </ul>
            </div>

            <div class="flex gap-3">
              <a href="https://wa.me/+5561974022227?text=Gostaria%20de%20or%C3%A7amento%20de%20ca%C3%A7ambras%20para%20entulhos" target="_blank" rel="noopener noreferrer" class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-3 px-4 rounded-lg text-center transition-colors">
                Solicitar Orçamento
              </a>
              <a href="/servicos/locacao-cacamba" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-900 font-bold py-3 px-4 rounded-lg text-center transition-colors">
                Saiba Mais
              </a>
            </div>
          </div>
        </div>

        <!-- Card 2: Tele Entulho -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow border-t-4 border-yellow-600">
