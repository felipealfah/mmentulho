                Solicitar Remoção
              </a>
              <a href="/servicos/tele-entulho" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-900 font-bold py-3 px-4 rounded-lg text-center transition-colors">
                Saiba Mais
              </a>
            </div>
          </div>
